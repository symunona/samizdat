[Unit]
Description=Samizdat server
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=symunona
Environment=HOME=/home/symunona
ExecStart=/usr/local/bin/samizdat serve
WorkingDirectory=/home/symunona/.samizdat
Restart=on-failure
RestartSec=3
# Bind :443 without running as root (needed for TLS post-M1):
AmbientCapabilities=CAP_NET_BIND_SERVICE

[Install]
WantedBy=multi-user.target
