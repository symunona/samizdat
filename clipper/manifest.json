{
  "manifest_version": 3,
  "name": "Save to Sam",
  "version": "0.1.0",
  "description": "Save the current page to your Samizdat instance, and jump back to it once saved.",
  "action": {
    "default_title": "Save to Sam",
    "default_icon": {
      "16": "icons/sam-off-16.png",
      "32": "icons/sam-off-32.png",
      "48": "icons/sam-off-48.png",
      "128": "icons/sam-off-128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "icons": {
    "16": "icons/sam-16.png",
    "32": "icons/sam-32.png",
    "48": "icons/sam-48.png",
    "128": "icons/sam-128.png"
  }
}
